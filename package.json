{
  "name": "mmd-editor",
  "productName": "MMD Editor",
  "version": "0.2.1",
  "description": "Visual editor for Mermaid flowcharts, with a live view for every Mermaid diagram type.",
  "author": "aukern",
  "license": "MIT",
  "homepage": "https://github.com/aukern/mmd-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/aukern/mmd-editor.git"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aukern.mmdeditor",
    "productName": "MMD Editor",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "electron/**/*",
      "LICENSE",
      "THIRD-PARTY-NOTICES.md"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Graphics",
      "icon": "build/icons",
      "maintainer": "aukern <noreply@users.noreply.github.com>",
      "synopsis": "Visual editor for Mermaid diagrams"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": "universal" }],
      "category": "public.app-category.graphics",
      "icon": "build/icon.png"
    },
    "publish": [
      { "provider": "github", "owner": "aukern", "repo": "mmd-editor" }
    ]
  }
}
